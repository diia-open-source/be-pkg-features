{
    "name": "@diia-inhouse/features",
    "version": "3.2.33",
    "type": "module",
    "description": "Features toggles",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-features",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsdown",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:coverage": "npm run test --selectProjects unit --coverage",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "semver": "7.7.4",
        "unleash-client": "6.10.1"
    },
    "peerDependencies": {
        "@diia-inhouse/env": ">=3.0.0",
        "@diia-inhouse/types": ">=13.1.0"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.3",
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/diia-logger": "4.3.28",
        "@diia-inhouse/env": "3.3.21",
        "@diia-inhouse/errors": "2.1.19",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/test": "8.2.14",
        "@diia-inhouse/types": "14.0.0",
        "@types/node": "25.6.2",
        "@types/semver": "7.7.1",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "tsdown": "0.22.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.5",
        "vitest-mock-extended": "4.0.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
