{
    "name": "@diia-inhouse/features",
    "version": "2.7.22",
    "description": "Features toggles",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-features",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:coverage": "npm run test --selectProjects unit --coverage",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "semver": "7.7.4",
        "unleash-client": "6.10.0"
    },
    "peerDependencies": {
        "@diia-inhouse/env": ">=1.14.0",
        "@diia-inhouse/types": ">=6.34.1"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.3",
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.19.10",
        "@diia-inhouse/env": "2.8.12",
        "@diia-inhouse/errors": "1.18.15",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.14",
        "@diia-inhouse/types": "12.0.1",
        "@types/node": "25.3.3",
        "@types/semver": "7.7.1",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.39.3",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.9",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
